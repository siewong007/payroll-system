  "query": "INSERT INTO user_totp (user_id, secret_encrypted, enabled, confirmed_at)\n        VALUES ($1, $2, false, NULL)\n        ON CONFLICT (user_id) DO UPDATE SET\n            secret_encrypted = EXCLUDED.secret_encrypted,\n            enabled = false,\n            confirmed_at = NULL,\n            updated_at = NOW()\n        RETURNING *",
