  "query": "SELECT t.id, t.company_id, t.name, t.description, t.tag, t.is_active,\n            t.created_at, t.updated_at,\n            (SELECT COUNT(*) FROM team_members tm WHERE tm.team_id = t.id) AS member_count\n        FROM teams t\n        WHERE t.company_id = $1\n        ORDER BY t.name",
