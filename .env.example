# Local Docker Compose database settings
POSTGRES_DB=payroll_db
POSTGRES_USER=payroll
POSTGRES_PORT=5434
POSTGRES_PASSWORD=payroll_secret_change_me

# Backend runtime settings
DATABASE_URL=postgres://payroll:payroll_secret_change_me@localhost:5434/payroll_db
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_EXPIRY_HOURS=1
RUST_LOG=info,payroll_system=debug
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
FRONTEND_URL=http://localhost:5173

# WebAuthn / passkey settings for local development
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_ORIGIN=http://localhost:5173

# Optional Google OAuth2 settings
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Optional SMTP settings for password reset and letters
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM_EMAIL=no-reply@example.com
# SMTP_FROM_NAME=Payroll System

# Optional frontend setting.
# Usually not needed in local development because Vite proxies /api to :8080.
# Add this to frontend/.env when the API is hosted on a different origin.
# VITE_API_URL=http://localhost:8080
